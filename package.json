<!DOCTYPE html>
<html lang="pt-BR">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>People Intelligence Hub — Daki</title>
<style>
*{box-sizing:border-box;margin:0;padding:0}
:root{--green:#1D9E75;--green-l:#e1f5ee;--green-d:#0f6e56;--red:#D85A30;--red-l:#faece7;--red-d:#993c1d;--amber:#EF9F27;--amber-l:#faeeda;--amber-d:#854f0b;--blue:#185FA5;--blue-l:#e6f1fb;--blue-d:#0c447c;--bg:#f8f7f4;--bg2:#fff;--bg3:#f0ede8;--text:#1a1a18;--text2:#6b6a66;--text3:#9e9c98;--border:#e0ddd8;--border2:#ccc9c3}
body{font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',sans-serif;background:var(--bg);color:var(--text);font-size:13px;line-height:1.5;min-height:100vh}
.app{max-width:780px;margin:0 auto;padding:20px 16px 40px}
.header{display:flex;align-items:center;gap:8px;margin-bottom:20px;padding-bottom:16px;border-bottom:1px solid var(--border)}
.logo-sq{width:8px;height:8px;border-radius:2px;background:var(--green);flex-shrink:0}
.header h1{font-size:16px;font-weight:600;flex:1}
.sync-pill{font-size:10px;padding:2px 8px;border-radius:99px;background:var(--green-l);color:var(--green-d);font-weight:500}

.tabs{display:flex;gap:5px;margin-bottom:14px;flex-wrap:wrap}
.tab{padding:6px 12px;border-radius:8px;font-size:12px;cursor:pointer;border:1px solid var(--border);background:var(--bg2);color:var(--text2);font-family:inherit;font-weight:400;transition:all .12s}
.tab.active{border-color:var(--green);background:var(--green-l);color:var(--green-d);font-weight:500}

.grid-3{display:grid;grid-template-columns:1fr 1fr 1fr;gap:8px;margin-bottom:10px}
.grid-2{display:grid;grid-template-columns:1fr 1fr;gap:8px;margin-bottom:10px}
@media(max-width:560px){.grid-3,.grid-2{grid-template-columns:1fr}}

.field label{display:block;font-size:11px;color:var(--text2);font-weight:500;margin-bottom:3px}
.field label .badge{font-size:9px;padding:1px 5px;border-radius:99px;background:var(--green-l);color:var(--green-d);font-weight:500;margin-left:4px}
input[type=text],input[type=date],select,textarea{width:100%;padding:7px 9px;border-radius:8px;border:1px solid var(--border);background:var(--bg2);color:var(--text);font-size:12px;font-family:inherit;transition:border-color .12s;-webkit-appearance:none}
input:focus,select:focus,textarea:focus{outline:none;border-color:var(--green)}
textarea{resize:vertical;line-height:1.6}

.dropdown-wrap{position:relative}
.dd{display:none;position:absolute;top:calc(100% + 2px);left:0;right:0;z-index:200;background:var(--bg2);border:1px solid var(--border2);border-radius:8px;max-height:170px;overflow-y:auto;box-shadow:0 4px 14px rgba(0,0,0,.1)}
.dd.open{display:block}
.ddi{padding:7px 10px;cursor:pointer;border-bottom:1px solid var(--border);font-size:12px;transition:background .1s}
.ddi:last-child{border-bottom:none}
.ddi:hover{background:var(--bg3)}
.ddi-main{font-weight:500}
.ddi-sub{font-size:10px;color:var(--text3);margin-top:1px}
.tag-pj{background:var(--amber-l);color:var(--amber-d);padding:1px 5px;border-radius:99px;font-size:9px;font-weight:500}
.tag-clt{background:var(--blue-l);color:var(--blue-d);padding:1px 5px;border-radius:99px;font-size:9px;font-weight:500}

.pills{display:flex;flex-wrap:wrap;gap:3px;margin-top:5px;min-height:4px}
.pill{display:inline-flex;align-items:center;gap:4px;padding:3px 8px;border-radius:99px;background:var(--green-l);color:var(--green-d);font-size:11px;font-weight:500}
.pill-x{cursor:pointer;opacity:.55;font-size:13px;line-height:1}
.pill-x:hover{opacity:1}

.dropzone{border:1.5px dashed var(--border2);border-radius:12px;padding:22px;text-align:center;cursor:pointer;background:var(--bg3);margin-bottom:10px;transition:all .15s}
.dropzone:hover,.dropzone.over{border-color:var(--green);background:var(--green-l)}
.dz-icon{font-size:24px;margin-bottom:6px}
.dz-title{font-size:13px;font-weight:500;margin-bottom:2px}
.dz-sub{font-size:11px;color:var(--text2)}
.dz-loaded{display:none;font-size:12px;color:var(--green-d);font-weight:500}

.meet-steps{display:flex;flex-direction:column;gap:5px;margin-bottom:10px}
.meet-step{display:flex;align-items:flex-start;gap:9px;padding:9px 11px;border-radius:8px;background:var(--bg3);border:1px solid var(--border)}
.step-n{width:19px;height:19px;border-radius:50%;background:var(--green);color:#fff;font-size:10px;font-weight:600;display:flex;align-items:center;justify-content:center;flex-shrink:0;margin-top:1px}
.step-t{font-size:12px;line-height:1.5;color:var(--text2)}
.step-t strong{color:var(--text);font-weight:500}
code{font-size:11px;background:var(--bg2);padding:1px 5px;border-radius:4px;border:1px solid var(--border);font-family:monospace}

.btn-main{width:100%;padding:10px;border-radius:8px;font-size:13px;font-weight:500;cursor:pointer;background:var(--green);color:#fff;border:none;font-family:inherit;margin-top:10px;transition:opacity .15s}
.btn-main:hover{opacity:.88}
.btn-main:disabled{opacity:.45;cursor:not-allowed}

.result-card{display:none;margin-top:14px;padding:16px;border-radius:12px;border:1px solid var(--border);background:var(--bg2)}
.result-card.show{display:block}
.result-header{display:flex;align-items:center;justify-content:space-between;margin-bottom:11px}
.result-title{font-size:13px;font-weight:600}
.btn-save{padding:6px 13px;font-size:11px;font-weight:500;border-radius:8px;background:var(--green);color:#fff;border:none;cursor:pointer;font-family:inherit}

.spinner-wrap{text-align:center;padding:20px}
.spinner{width:20px;height:20px;border-radius:50%;border:2px solid var(--border);border-top-color:var(--green);animation:spin .7s linear infinite;margin:0 auto 8px}
@keyframes spin{to{transform:rotate(360deg)}}
.spinner-txt{font-size:12px;color:var(--text2)}

.tags-row{display:flex;flex-wrap:wrap;gap:4px;margin-bottom:10px}
.badge{font-size:10px;padding:2px 8px;border-radius:99px;font-weight:500;white-space:nowrap}
.b-r{background:var(--red-l);color:var(--red-d)}
.b-a{background:var(--amber-l);color:var(--amber-d)}
.b-g{background:var(--green-l);color:var(--green-d)}
.b-bl{background:var(--blue-l);color:var(--blue-d)}
.b-n{background:var(--bg3);color:var(--text2)}
.summary{font-size:12px;line-height:1.7}
.section-sub{margin-top:10px;padding-top:10px;border-top:1px solid var(--border)}
.section-sub-title{font-size:10px;color:var(--text3);font-weight:500;margin-bottom:5px;text-transform:uppercase;letter-spacing:.5px}
.action-item{display:flex;align-items:flex-start;gap:5px;font-size:12px;padding:2px 0;color:var(--text2)}
.action-arr{color:var(--green);font-size:11px;margin-top:2px;flex-shrink:0}

.err-box{display:none;margin-top:10px;padding:9px 12px;border-radius:8px;background:var(--red-l);color:var(--red-d);font-size:12px;line-height:1.5}

.history{margin-top:20px;padding-top:18px;border-top:1px solid var(--border)}
.history-title{font-size:12px;font-weight:600;margin-bottom:10px;color:var(--text2)}
.entry{display:flex;align-items:center;gap:8px;padding:8px 11px;border-radius:8px;background:var(--bg2);border:1px solid var(--border);margin-bottom:5px;font-size:11px}
.entry-date{color:var(--text3);min-width:58px;font-size:10px;font-weight:500}
.entry-type{padding:2px 6px;border-radius:99px;font-size:10px;font-weight:500;background:var(--bg3);border:1px solid var(--border);white-space:nowrap;flex-shrink:0}
.entry-person{font-weight:500;min-width:90px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}
.entry-area{color:var(--text2);flex:1;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}
.entry-themes{display:flex;gap:3px;flex-shrink:0}
.entry-theme{font-size:10px;padding:1px 5px;border-radius:99px;background:var(--green-l);color:var(--green-d)}
.empty-state{font-size:11px;color:var(--text3);padding:8px 0}

.footer{text-align:center;font-size:10px;color:var(--text3);margin-top:16px}
</style>
</head>
<body>
<div class="app">

<div class="header">
  <div class="logo-sq"></div>
  <h1>People Intelligence Hub</h1>
  <span class="sync-pill">Daki HRBP</span>
</div>

<div class="tabs">
  <button class="tab active" onclick="switchMode('text',this)">Texto livre</button>
  <button class="tab" onclick="switchMode('audio',this)">Upload de audio</button>
  <button class="tab" onclick="switchMode('meet',this)">Transcricao Meet</button>
</div>

<div class="grid-3">
  <div class="field">
    <label>Data da informacao</label>
    <input type="date" id="inp-date">
  </div>
  <div class="field">
    <label>Tipo de fonte</label>
    <select id="inp-type">
      <option value="">Selecionar...</option>
      <option>Bate-papo / conversa</option>
      <option>Pesquisa e-NPS</option>
      <option>Entrevista de desligamento</option>
      <option>Entrevista por tempo de experiencia</option>
      <option>1:1 com lideranca</option>
      <option>Feedback 360</option>
      <option>Reuniao de time</option>
      <option>Observacao / nota livre</option>
    </select>
  </div>
  <div class="field">
    <label>Vinculo</label>
    <select>
      <option>Todos / nao sei</option>
      <option>CLT</option><option>PJ</option><option>Estagio</option>
    </select>
  </div>
</div>

<div class="grid-2">
  <div class="field">
    <label>Area / departamento <span class="badge">Snowflake</span></label>
    <div class="dropdown-wrap">
      <input type="text" id="dept-inp" placeholder="Buscar departamento..." autocomplete="off"
        oninput="filterDept(this.value)" onfocus="filterDept(this.value)">
      <div class="dd" id="dept-dd"></div>
    </div>
    <div id="dept-bc" style="font-size:10px;color:var(--text3);margin-top:3px;min-height:13px"></div>
  </div>
  <div class="field">
    <label>Pessoa(s) envolvida(s) <span class="badge">Snowflake</span></label>
    <div class="dropdown-wrap">
      <input type="text" id="person-inp" placeholder="Buscar colaborador..." autocomplete="off"
        oninput="filterPeople(this.value)" onfocus="filterPeople(this.value)">
      <div class="dd" id="people-dd"></div>
    </div>
    <div class="pills" id="sel-pills"></div>
  </div>
</div>

<div id="panel-text">
  <div class="field">
    <label>Texto bruto</label>
    <textarea id="inp-text" rows="5" placeholder="Cole qualquer texto: anotacao de conversa, resposta de pesquisa, transcricao, e-mail, nota rapida..."></textarea>
  </div>
</div>

<div id="panel-audio" style="display:none">
  <div class="dropzone" id="dropzone"
    onclick="document.getElementById('file-input').click()"
    ondragover="event.preventDefault();this.classList.add('over')"
    ondragleave="this.classList.remove('over')"
    ondrop="handleDrop(event)">
    <div id="dz-idle">
      <div class="dz-icon">&#9835;</div>
      <div class="dz-title">Clique ou arraste o arquivo de audio aqui</div>
      <div class="dz-sub">.mp3 .mp4 .m4a .wav .ogg — qualquer formato de audio</div>
    </div>
    <div id="dz-loaded" class="dz-loaded">
      <div id="dz-filename"></div>
      <div style="font-size:11px;color:var(--green-d);margin-top:2px">Pronto — clique em Analisar abaixo</div>
    </div>
  </div>
  <input type="file" id="file-input" accept="audio/*,video/mp4,.mp4,.m4a,.mp3,.wav,.ogg,.webm" style="display:none" onchange="loadFile(this.files[0])">
  <div id="audio-player-wrap" style="display:none;margin-bottom:10px">
    <audio id="audio-player" controls style="width:100%"></audio>
  </div>
  <div class="field">
    <label>Transcricao (preenchida automaticamente pela IA)</label>
    <textarea id="inp-audio-text" rows="3" placeholder="Aparece aqui apos analisar..."></textarea>
  </div>
</div>

<div id="panel-meet" style="display:none">
  <div class="meet-steps">
    <div class="meet-step">
      <div class="step-n">1</div>
      <div class="step-t">No Meet, ative <strong>Legendas automaticas</strong> (icone CC) durante a chamada</div>
    </div>
    <div class="meet-step">
      <div class="step-n">2</div>
      <div class="step-t">Ao final: <strong>Atividades → Transcricoes</strong> — salvo automaticamente no Google Drive</div>
    </div>
    <div class="meet-step">
      <div class="step-n">3</div>
      <div class="step-t">Abra o doc, <code>Ctrl+A</code> → <code>Ctrl+C</code> e cole abaixo</div>
    </div>
  </div>
  <div class="field">
    <label>Transcricao do Google Meet</label>
    <textarea id="inp-meet" rows="6" placeholder="[10:02] Laura: sobre a carga do time...&#10;[10:05] Rafael: concordo..."></textarea>
  </div>
</div>

<div class="err-box" id="err-box"></div>

<button class="btn-main" id="analyze-btn" onclick="analyze()">
  Analisar com IA e extrair insights
</button>

<div class="result-card" id="result-card">
  <div class="spinner-wrap" id="spinner-wrap">
    <div class="spinner"></div>
    <div class="spinner-txt" id="spinner-txt">Processando...</div>
  </div>
  <div id="result-body" style="display:none">
    <div class="result-header">
      <span class="result-title">Insights extraidos</span>
      <button class="btn-save" onclick="saveEntry()">Confirmar e salvar</button>
    </div>
    <div class="tags-row" id="tags-row"></div>
    <div class="summary" id="summary-text"></div>
    <div class="section-sub" id="transcript-section" style="display:none">
      <div class="section-sub-title">Transcricao do audio</div>
      <div id="transcript-text" style="font-size:11px;color:var(--text2);line-height:1.6"></div>
    </div>
    <div class="section-sub" id="actions-section" style="display:none">
      <div class="section-sub-title">Acoes recomendadas</div>
      <div id="actions-list"></div>
    </div>
  </div>
</div>

<div class="history">
  <div class="history-title">Entradas salvas nesta sessao</div>
  <div id="entries-list">
    <div class="empty-state">Nenhuma entrada ainda. Adicione dados acima.</div>
  </div>
</div>

<div class="footer">IA via Claude · Colaboradores: Snowflake IL_PII + Folha PJ · Depts: GSHEET_DAKI_PEOPLE_DEPARTAMENTOS</div>

</div>

