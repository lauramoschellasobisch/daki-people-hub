  {n:"VALERIA CARLOS SILVA",c:"GERENTE DE OPERACOES",d:"OPERATIONS STORE",t:"CLT"},
];

const DEPTS=["S&P","TECHNOLOGY","PEOPLE","FINANCE","LEGAL","RETAIL","GROWTH","CX","OPERATIONS HQ","OPERATIONS STORE","SUPPLY HQ","SUPPLY CD","TECHNOLOGY > SOFTWARE ENGINEERING","TECHNOLOGY > SOFTWARE ENGINEERING > QUALITY","TECHNOLOGY > PRODUCT FULFILLMENT","TECHNOLOGY > PRODUCT CUSTOMER & DESIGN","TECHNOLOGY > DATA","TECHNOLOGY > DATA > DATA ANALYTICS","TECHNOLOGY > DATA > DATA ENGINEERING","PEOPLE > HRBP","PEOPLE > HRBP > CORPORATE","PEOPLE > HRBP > OPERATIONS","PEOPLE > TALENT ACQUISITION","PEOPLE > TALENT ACQUISITION > CORP","PEOPLE > TALENT ACQUISITION > OPS","PEOPLE > TALENT MANAGEMENT","PEOPLE > TOTAL REWARDS","PEOPLE > TOTAL REWARDS > HROPS","PEOPLE > TOTAL REWARDS > PEOPLE ANALYTICS","FINANCE > ACCOUNTING & TAX","FINANCE > FPA & GOVERNANCE","FINANCE > TREASURY","RETAIL > COMMERCIAL > CAT GROCERY","RETAIL > COMMERCIAL > CAT LIQUID","RETAIL > COMMERCIAL > CAT NON FOOD","RETAIL > COMMERCIAL > CAT PEREFRESH","RETAIL > SALES DEVELOPMENT","RETAIL > CHANNELS & PARTNERSHIP","GROWTH > MARKETING > BRANDING","GROWTH > MARKETING > CRM","GROWTH > MARKETING > PAID MEDIA","GROWTH > MARKETING > RETAIL MEDIA","OPERATIONS HQ > DCS","OPERATIONS HQ > HUBS","OPERATIONS HQ > OPS INTELLIGENCE","OPERATIONS HQ > QUALITY & TRAINING","OPERATIONS HQ > RIDERS OPERATION","OPERATIONS HQ > RIDERS > ACQUISITION","OPERATIONS HQ > RIDERS > BALANCE & ENGAGEMENT","SUPPLY HQ > SUPPLY CHAIN","SUPPLY HQ > SUPPLY CHAIN > CENTRAL TEAM","SUPPLY HQ > SUPPLY CHAIN > DRY","SUPPLY HQ > SUPPLY CHAIN > PEREFRESH","SUPPLY HQ > SUPPLY CHAIN > LOSS PREVENTION","SUPPLY HQ > EXCELLENCE","SUPPLY HQ > EXCELLENCE > CONTINUOUS IMPROVEMENT","SUPPLY HQ > EXCELLENCE > FULFILLMENT DESIGN","SUPPLY CD > DCS HANDLING"];

let curMode='text', selPeople=[], selDept='', audioB64=null, audioMime='audio/mp4', lastResult=null, entries=[];

document.getElementById('inp-date').value=new Date().toISOString().split('T')[0];

function switchMode(m,el){
  curMode=m;
  document.querySelectorAll('.tab').forEach(t=>{t.classList.remove('active')});
  el.classList.add('active');
  ['text','audio','meet'].forEach(x=>document.getElementById('panel-'+x).style.display=x===m?'block':'none');
}

function filterDept(q){
  const dd=document.getElementById('dept-dd');
  const res=q?DEPTS.filter(d=>d.toLowerCase().includes(q.toLowerCase())).slice(0,10):DEPTS.slice(0,10);
  if(!res.length){dd.classList.remove('open');return}
  dd.innerHTML=res.map(d=>`<div class="ddi" onclick="selectDept('${d.replace(/'/g,"\\'")}')"><div class="ddi-main">${d}</div></div>`).join('');
  dd.classList.add('open');
}
function selectDept(d){
  selDept=d;
  document.getElementById('dept-inp').value=d;
  document.getElementById('dept-dd').classList.remove('open');
  document.getElementById('dept-bc').innerHTML=`<strong>${d}</strong>`;
}

function filterPeople(q){
  const dd=document.getElementById('people-dd');
  if(!q){dd.classList.remove('open');return}
  const res=PEOPLE.filter(p=>p.n.toLowerCase().includes(q.toLowerCase())||p.c.toLowerCase().includes(q.toLowerCase())).slice(0,8);
  if(!res.length){dd.classList.remove('open');return}
  dd.innerHTML=res.map(p=>`<div class="ddi" onclick="addPerson('${p.n.replace(/'/g,"\\'")}','${p.c.replace(/'/g,"\\'")}','${p.d}','${p.t}')"><div class="ddi-main">${tc(p.n)}</div><div class="ddi-sub"><span class="${p.t==='PJ'?'tag-pj':'tag-clt'}">${p.t}</span> ${p.c} · ${p.d}</div></div>`).join('');
  dd.classList.add('open');
}
function addPerson(n,c,d,t){
  if(selPeople.find(x=>x.n===n))return;
  selPeople.push({n,c,d,t});
  document.getElementById('person-inp').value='';
  document.getElementById('people-dd').classList.remove('open');
  if(!selDept)selectDept(d);
  renderPills();
}
function removePerson(n){selPeople=selPeople.filter(x=>x.n!==n);renderPills()}
function renderPills(){
  document.getElementById('sel-pills').innerHTML=selPeople.map(p=>`<span class="pill">${tc(p.n)}<span class="pill-x" onclick="removePerson('${p.n.replace(/'/g,"\\'")}')">×</span></span>`).join('');
}

function loadFile(file){
  if(!file)return;
  const ext=file.name.split('.').pop().toLowerCase();
  const mm={mp3:'audio/mpeg',mp4:'audio/mp4',m4a:'audio/mp4',wav:'audio/wav',ogg:'audio/ogg',webm:'audio/webm',aac:'audio/aac'};
  audioMime=(file.type&&file.type!=='application/octet-stream')?file.type:(mm[ext]||'audio/mp4');
  document.getElementById('dz-idle').style.display='none';
  document.getElementById('dz-loaded').style.display='block';
  document.getElementById('dz-filename').textContent='Carregando: '+file.name+'...';
  const reader=new FileReader();
  reader.onload=e=>{
    const dataUrl=e.target.result;
    audioB64=dataUrl.split(',')[1];
    document.getElementById('audio-player').src=dataUrl;
    document.getElementById('audio-player-wrap').style.display='block';
    document.getElementById('dz-filename').textContent=file.name+' ('+Math.round(file.size/1024)+' KB) — pronto';
    document.getElementById('dz-filename').style.color='var(--green-d)';
  };
  reader.onerror=()=>{document.getElementById('dz-filename').textContent='Erro ao ler arquivo. Tente novamente.';};
  reader.readAsDataURL(file);
}
function handleDrop(e){
  e.preventDefault();
  document.getElementById('dropzone').classList.remove('over');
  loadFile(e.dataTransfer.files[0]);
}

function tc(s){return s.toLowerCase().replace(/\b\w/g,c=>c.toUpperCase())}
function showErr(msg){const el=document.getElementById('err-box');el.textContent=msg;el.style.display=msg?'block':'none'}

function getActiveText(){
  if(curMode==='audio')return document.getElementById('inp-audio-text').value.trim();
  if(curMode==='meet')return document.getElementById('inp-meet').value.trim();
  return document.getElementById('inp-text').value.trim();
}

async function analyze(){
  showErr('');
  const text=getActiveText();
  const hasAudio=curMode==='audio'&&audioB64&&!text;
  if(!hasAudio&&!text){
    showErr(curMode==='audio'?'Faca o upload de um arquivo de audio ou cole a transcricao.':'Adicione um texto para analisar.');
    return;
  }
  const area=selDept||document.getElementById('dept-inp').value||'nao especificada';
  const srcType=document.getElementById('inp-type').value||'nao informado';
  const people=selPeople.map(p=>tc(p.n)).join(', ')||'nao informado';
  const date=document.getElementById('inp-date').value;

  const btn=document.getElementById('analyze-btn');
  btn.disabled=true;btn.textContent='Analisando...';

  const card=document.getElementById('result-card');
  const spinWrap=document.getElementById('spinner-wrap');
  const resultBody=document.getElementById('result-body');
  card.classList.add('show');
  spinWrap.style.display='block';
  resultBody.style.display='none';
  document.getElementById('spinner-txt').textContent=hasAudio?'Transcrevendo audio e extraindo insights...':'Extraindo temas, sentimento e prioridades...';

  try{
    const payload={text,area,srcType,people,date};
    if(hasAudio){payload.audioB64=audioB64;payload.audioMime=audioMime;}

    const res=await fetch('/api/analyze',{
      method:'POST',
      headers:{'Content-Type':'application/json'},
      body:JSON.stringify(payload)
    });
    if(!res.ok){
      const err=await res.json().catch(()=>({error:'Erro desconhecido'}));
      throw new Error(err.error||'HTTP '+res.status);
    }
    const parsed=await res.json();
    lastResult=parsed;

    if(parsed.transcript&&!document.getElementById('inp-audio-text').value){
      document.getElementById('inp-audio-text').value=parsed.transcript;
    }

    const uc={critico:['var(--red-l)','var(--red-d)'],urgente:['var(--red-l)','var(--red-d)'],atencao:['var(--amber-l)','var(--amber-d)'],informativo:['var(--bg3)','var(--text2)']};
    const sc={positivo:['var(--green-l)','var(--green-d)'],negativo:['var(--red-l)','var(--red-d)'],neutro:['var(--bg3)','var(--text2)'],misto:['var(--amber-l)','var(--amber-d)']};
    const ub=uc[parsed.urgency]||uc.informativo;
    const sb=sc[parsed.sentiment]||sc.neutro;
    const bdg=(t,bg,c)=>`<span class="badge" style="background:${bg};color:${c}">${t}</span>`;

    document.getElementById('tags-row').innerHTML=[
      bdg(parsed.area||area,'var(--blue-l)','var(--blue-d)'),
      bdg(parsed.urgency,ub[0],ub[1]),
      bdg(parsed.sentiment,sb[0],sb[1]),
      ...(parsed.themes||[]).map(t=>bdg(t,'var(--green-l)','var(--green-d)'))
    ].join('');

    document.getElementById('summary-text').textContent=parsed.summary||'';

    const ts=document.getElementById('transcript-section');
    if(parsed.transcript){document.getElementById('transcript-text').textContent=parsed.transcript;ts.style.display='block';}
    else{ts.style.display='none';}

    const as=document.getElementById('actions-section');
    if(parsed.actions?.length){
      document.getElementById('actions-list').innerHTML=parsed.actions.map(a=>`<div class="action-item"><span class="action-arr">→</span>${a}</div>`).join('');
      as.style.display='block';
    }else{as.style.display='none';}

    spinWrap.style.display='none';
    resultBody.style.display='block';

  }catch(err){
    card.classList.remove('show');
    showErr('Erro: '+(err.message||'Tente novamente.'));
  }

  btn.disabled=false;btn.textContent='Analisar com IA e extrair insights';
}

function saveEntry(){
  if(!lastResult)return;
  const d=document.getElementById('inp-date').value.split('-');
  entries.unshift({
    date:`${d[2]}/${d[1]}/${d[0]}`,
    type:document.getElementById('inp-type').value||'Nota',
    person:selPeople.length?tc(selPeople[0].n):'—',
    area:selDept||document.getElementById('dept-inp').value||'Geral',
    themes:(lastResult.themes||[]).slice(0,2)
  });

  document.getElementById('result-card').classList.remove('show');
  ['inp-text','inp-audio-text','inp-meet'].forEach(x=>document.getElementById(x).value='');
  document.getElementById('dept-inp').value='';
  document.getElementById('dept-bc').innerHTML='';
  document.getElementById('person-inp').value='';
  selPeople=[];selDept='';audioB64=null;lastResult=null;
  renderPills();
  document.getElementById('inp-date').value=new Date().toISOString().split('T')[0];
  document.getElementById('inp-type').value='';
  document.getElementById('audio-player-wrap').style.display='none';
  document.getElementById('audio-player').src='';
  document.getElementById('dz-idle').style.display='block';
  document.getElementById('dz-loaded').style.display='none';
  document.getElementById('file-input').value='';
  renderEntries();
}

function renderEntries(){
  const el=document.getElementById('entries-list');
  if(!entries.length){el.innerHTML='<div class="empty-state">Nenhuma entrada ainda.</div>';return}
  el.innerHTML=entries.map(e=>`
    <div class="entry">
      <span class="entry-date">${e.date}</span>
      <span class="entry-type">${e.type}</span>
      <span class="entry-person">${e.person}</span>
      <span class="entry-area">${e.area}</span>
      <div class="entry-themes">${e.themes.map(t=>`<span class="entry-theme">${t}</span>`).join('')}</div>
    </div>`).join('');
}

document.addEventListener('click',e=>{
  if(!e.target.closest('#dept-inp')&&!e.target.closest('#dept-dd'))document.getElementById('dept-dd').classList.remove('open');
  if(!e.target.closest('#person-inp')&&!e.target.closest('#people-dd'))document.getElementById('people-dd').classList.remove('open');
});
</script>
</body>
</html>
